# Database
DATABASE_URL=postgres://quill:quill_dev_password@localhost:5432/quill?sslmode=disable
DB_MAX_CONNECTIONS=25
DB_MAX_IDLE_CONNECTIONS=5

# Qwen Cloud
QWEN_API_KEY=sk-your-qwen-api-key-here
LLM_PROTOCOL=openai
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_NATIVE_BASE_URL=https://dashscope-intl.aliyuncs.com
QWEN_EXTRACTION_MODEL=qwen-turbo
QWEN_REASONING_MODEL=qwen-max
QWEN_CRAFT_MODEL=qwen-max
QWEN_FALLBACK_MODEL=qwen-plus
QWEN_FALLBACK_ON_429=false
QWEN_RERANK_MODEL=qwen3-rerank
QWEN_API_TIMEOUT_SECONDS=120
QWEN_EMBEDDING_MODEL=text-embedding-v4
QWEN_EMBEDDING_DIMENSIONS=1024

# Auth
JWT_SECRET=your-256-bit-secret-here
JWT_EXPIRATION_HOURS=24
BCRYPT_COST=12

# Server
PORT=8080
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# File Upload
MAX_UPLOAD_SIZE_MB=100
UPLOAD_DIR=./uploads
SKILL_DIR=./skills

# Analysis
DEBOUNCE_SECONDS=5
RELEVANCE_DECAY_LAMBDA=0.1
ARCHIVE_THRESHOLD=0.15
REACTIVATION_SCORE=0.8
PLOT_HOLE_STALE_THRESHOLD=8
MAX_CONTRADICTION_CANDIDATES=3
CONTRADICTION_AGENT_DEPTH=3
PLOT_HOLE_AGENT_DEPTH=2

# Qwen Rate Limiting
LLM_TPM_TURBO=5000000
LLM_TPM_MAX=1000000
LLM_RPM=600
LLM_INTERACTIVE_RESERVE=0.30
LLM_MAX_CONCURRENCY=5
LLM_RAMP_STEP=1
QWEN_RETRY_MAX_ATTEMPTS=3

# Context Budget
QWEN_MAX_CONTEXT_TOKENS=30000
QWEN_RESPONSE_RESERVE=2000

# Migrations
MIGRATIONS_DIR=./migrations

# Post-ingest analysis (contradiction/plot-hole checks after upload; placeholder cap)
INGEST_ANALYSIS_MAX_CHAPTERS=8
WRITER_PREFERENCE_PROMOTION_THRESHOLD=3
